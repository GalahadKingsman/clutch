# nginx + production Mini App build (no host npm required on VPS)
FROM node:20-alpine AS miniapp
WORKDIR /build
COPY apps/miniapp/package.json ./
RUN npm install
COPY apps/miniapp/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx/nginx.conf /etc/nginx/nginx.conf
COPY --from=miniapp /build/dist /usr/share/nginx/html
