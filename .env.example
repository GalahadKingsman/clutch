# ─── App ───────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info

# ─── URLs (замени на реальные домены на VPS) ───────────
# Один домен: nginx отдаёт Mini App и проксирует /api + /telegram/webhook
PUBLIC_URL=https://your-domain.example
API_PUBLIC_URL=https://your-domain.example
MINIAPP_PUBLIC_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example
TELEGRAM_WEBHOOK_PUBLIC_URL=https://your-domain.example/telegram/webhook

# ─── Telegram (@clutch_game_bot) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=clutch_game_bot
# Секрет для заголовка X-Telegram-Bot-Api-Secret-Token (задай сам)
TELEGRAM_WEBHOOK_SECRET=

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-to-long-random-string

# ─── Database (docker-compose defaults) ────────────────
POSTGRES_USER=clutch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=clutch
DATABASE_URL=postgres://clutch:change-me@postgres:5432/clutch?sslmode=disable

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Solana (devnet для Phase 0) ───────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# После anchor deploy:
CLUTCH_PROGRAM_ID=
CLUTCH_TREASURY_PUBKEY=

# ─── Ports (host mapping) ──────────────────────────────
API_PORT=8080
BOT_WEBHOOK_PORT=8081
